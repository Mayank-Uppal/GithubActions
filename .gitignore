# ─── Node / NPM ───────────────────────────────────────────────
# Both client and server have node_modules — exclude all of them.
# These are reproducible via `npm install`. Committing them bloats
# the repo and causes platform-specific binary issues in CI.
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Environment Variables ────────────────────────────────────
# NEVER commit .env files. They contain secrets like:
# MONGO_URI, JWT_SECRET, API keys.
# GitHub Secrets (added later) replace these in CI/CD.
.env
.env.local
.env.development
.env.production
.env.*.local

# ─── Build Outputs ────────────────────────────────────────────
# Vite compiles your React app into client/dist/.
# This is regenerated in CI — no need to commit it.
client/dist/
client/.vite/

# ─── OS junk ──────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor files ─────────────────────────────────────────────
.vscode/settings.json
.idea/

# ─── Docker ───────────────────────────────────────────────────
# docker-compose.override.yml is often used for local dev overrides
# (like mounting volumes) that shouldn't affect production.
docker-compose.override.yml